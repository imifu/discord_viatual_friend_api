# --- Discord Bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- OpenAI Realtime API ---
OPENAI_API_KEY=
# Realtime model to connect to.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# Built-in voices: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar.
# OpenAI recommends marin/cedar for best quality.
OPENAI_VOICE=marin

# --- Audio format (Discord side only; the Realtime API always uses 24kHz mono internally) ---
INPUT_SAMPLE_RATE=48000
INPUT_CHANNELS=2

OUTPUT_SAMPLE_RATE=48000
OUTPUT_CHANNELS=2

# --- Logging ---
# one of: debug, info, warn, error
LOG_LEVEL=info

# --- Anti-howling ducking ---
# Whether to duck (attenuate) Discord->API audio while the model is speaking, instead of muting it fully
DISCORD_INPUT_DUCKING=true
# Attenuation level (0-1) applied to Discord->API audio while ducking is active
DISCORD_INPUT_DUCKING_LEVEL=0.1

# --- Smart barge-in ---
# Whether user speech should be allowed to interrupt the model. Interruption itself (and detecting
# that the user started/stopped talking) is handled by the Realtime API's own server-side VAD;
# this only controls how much to duck the model's Discord-side playback volume while it happens.
BARGE_IN_ENABLED=true
# Model->Discord playback gain during barge-in (0=silent, 1=unchanged)
BARGE_IN_GPT_PLAYBACK_LEVEL=0.2

# --- Air-reading prompt ---
# Sent automatically as the Realtime session's `instructions` - no manual copy/paste needed.
# /airprompt shows the currently configured prompt for reference.
AIR_READING_ENABLED=true
# Optional one-line override. Use literal \n sequences for line breaks.
# AIR_READING_PROMPT=
