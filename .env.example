# --- Discord Bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- OpenAI Realtime API ---
OPENAI_API_KEY=
# Realtime model to connect to. gpt-realtime-2.1-mini costs roughly 1/3 of gpt-realtime-2.1
# (see README "API使用料金の試算") at some cost to conversational quality - try both.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
# Built-in voices: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar.
# OpenAI recommends marin/cedar for best quality.
OPENAI_VOICE=marin

# --- Audio format (Discord side only; the Realtime API always uses 24kHz mono internally) ---
INPUT_SAMPLE_RATE=48000
INPUT_CHANNELS=2

OUTPUT_SAMPLE_RATE=48000
OUTPUT_CHANNELS=2

# --- Logging ---
# one of: debug, info, warn, error
LOG_LEVEL=info

# --- Idle auto-stop (cost control) ---
# Discord audio streams to the Realtime API continuously for the whole relay session, so input
# cost accrues even while nobody is talking. Auto-/stop after this many minutes with no speech
# from either side, so a forgotten /start doesn't keep costing money. 0 disables it.
IDLE_TIMEOUT_MINUTES=15

# --- Smart barge-in ---
# Discord's mic audio is always forwarded to the Realtime API at full strength, even while the
# model is speaking, so its own server-side VAD can always detect a real interruption
# (input_audio_buffer.speech_started/stopped) - it is never locally muted or attenuated first.
# BARGE_IN_ENABLED only controls how much to duck the model's own Discord-side playback volume
# once such an interruption is detected.
BARGE_IN_ENABLED=true
# Model->Discord playback gain during barge-in (0=silent, 1=unchanged)
BARGE_IN_GPT_PLAYBACK_LEVEL=0.2

# --- Air-reading prompt ---
# Sent automatically as the Realtime session's `instructions` - no manual copy/paste needed.
# /airprompt shows the currently configured prompt for reference.
AIR_READING_ENABLED=true
# Optional one-line override. Use literal \n sequences for line breaks.
# AIR_READING_PROMPT=
